#!/usr/bin/env bash
set -euo pipefail
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "❌ gitleaks not installed — refusing to push unscanned. Install: https://github.com/gitleaks/gitleaks#installing (or your package manager), then retry." >&2
  exit 1
fi
zero="0000000000000000000000000000000000000000"
status=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue
  if [ "$remote_sha" = "$zero" ]; then
    range="$local_sha --not --remotes"
  else
    range="$remote_sha..$local_sha"
  fi
  gitleaks detect --redact --verbose --no-banner --log-opts="$range" || status=1
done
exit $status
