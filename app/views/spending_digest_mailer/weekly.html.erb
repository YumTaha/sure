<%# app/views/spending_digest_mailer/weekly.html.erb %>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:600px;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 1px 3px rgba(15,23,42,.08);margin:0 auto;">
  <tr><td style="background:#059669;padding:24px 28px;">
    <div style="font:700 18px/1.2 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#ffffff;"><%= t("spending_digest_mailer.weekly.heading") %></div>
    <div style="font:400 13px/1.2 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#d1fae5;margin-top:4px;"><%= @digest.range_label %></div>
  </td></tr>
  <tr><td style="padding:22px 20px 8px;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
      <td width="33%" style="padding:0 8px;vertical-align:top;">
        <div style="background:#ecfdf5;border-radius:12px;padding:14px;text-align:center;">
          <div style="font:600 11px/1 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#059669;text-transform:uppercase;letter-spacing:.8px;"><%= t("spending_digest_mailer.weekly.posted") %></div>
          <div style="font:700 22px/1.2 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#065f46;margin-top:6px;font-variant-numeric:tabular-nums;"><%= @digest.posted_total.format %></div>
        </div>
      </td>
      <td width="33%" style="padding:0 8px;vertical-align:top;">
        <div style="background:#fffbeb;border-radius:12px;padding:14px;text-align:center;">
          <div style="font:600 11px/1 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#d97706;text-transform:uppercase;letter-spacing:.8px;"><%= t("spending_digest_mailer.weekly.pending") %></div>
          <div style="font:700 22px/1.2 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#92400e;margin-top:6px;font-variant-numeric:tabular-nums;"><%= @digest.pending_total.format %></div>
        </div>
      </td>
      <td width="33%" style="padding:0 8px;vertical-align:top;">
        <div style="background:#eef2ff;border-radius:12px;padding:14px;text-align:center;">
          <div style="font:600 11px/1 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#4f46e5;text-transform:uppercase;letter-spacing:.8px;"><%= t("spending_digest_mailer.weekly.estimated") %></div>
          <div style="font:700 22px/1.2 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#3730a3;margin-top:6px;font-variant-numeric:tabular-nums;"><%= @digest.estimated_total.format %></div>
        </div>
      </td>
    </tr></table>
  </td></tr>
  <tr><td style="padding:18px 28px 4px;">
    <div style="font:700 13px/1 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#334155;"><%= t("spending_digest_mailer.weekly.by_category") %></div>
  </td></tr>
  <tr><td style="padding:0 28px 16px;">
    <% if @digest.posted_categories.any? %>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <% @digest.posted_categories.each do |line| %>
          <tr><td style="padding:12px 0 4px;">
              <table role="presentation" width="100%"><tr>
                <td style="font:500 14px/1 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#0f172a;"><%= line.name %></td>
                <td style="font:600 14px/1 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#0f172a;text-align:right;font-variant-numeric:tabular-nums;"><%= line.amount.format %></td>
              </tr></table>
              <div style="margin-top:6px;">
                <div style="height:8px;background:#f1f5f9;border-radius:6px;overflow:hidden;">
                  <div style="height:8px;width:<%= line.pct %>%;background:#059669;border-radius:6px;"></div>
                </div>
              </div>
            </td></tr>
        <% end %>
      </table>
    <% else %>
      <p style="font:400 14px/1.5 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#64748b;margin:0;"><%= t("spending_digest_mailer.weekly.no_spending") %></p>
    <% end %>
  </td></tr>
  <tr><td style="padding:0 28px 26px;">
    <div style="background:#fffbeb;border-left:3px solid #f59e0b;border-radius:6px;padding:10px 12px;font:400 12px/1.5 -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#92400e;"><%= t("spending_digest_mailer.weekly.caveat") %></div>
  </td></tr>
</table>
